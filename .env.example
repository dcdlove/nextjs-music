# ==========================================
# Admin upload auth
# ==========================================
# Token used by /admin page and /api/admin/songs
ADMIN_TOKEN=test

# ==========================================
# GitHub repository write/read config
# ==========================================
# Fine-grained PAT with repository contents write permission
GITHUB_TOKEN=test
GITHUB_OWNER=dcdlove
GITHUB_REPO=oss
GITHUB_BRANCH=main
GITHUB_MUSIC_DIR=music
GITHUB_PLAYLIST_PATH=music/data.json

# ==========================================
# Upload size limit (MB)
# ==========================================
# Recommended: 4 on Vercel Hobby, larger for local development
MAX_UPLOAD_MB=4

